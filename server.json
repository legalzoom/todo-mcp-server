{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.gitops-ci-cd/todo-mcp-server",
  "title": "Todo MCP Server",
  "description": "A demo MCP server showcasing best practices and full MCP spec functionality via a todo domain",
  "repository": {
